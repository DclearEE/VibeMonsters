# Copy to .env and fill in. .env is gitignored.

# Anthropic API key — text generation (monster + battle)
ANTHROPIC_API_KEY=sk-ant-...

# Google GenAI API key — sprite generation via Gemini 2.5 Flash Image
GEMINI_API_KEY=...

# Public API base URL — used by the client for API calls.
# Same-origin in dev and Docker: leave blank or set to ''.
# Capacitor / separate frontend deploy: set to the hosted API URL.
PUBLIC_API_BASE_URL=
